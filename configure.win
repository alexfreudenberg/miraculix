
#!/bin/bash
USE_FLAGS=false #true

if $USE_FLAGS ; then
  MIRACULIX_CXXFLAGS="-mtune=generic -mavx -O2 $CXX_FLAGS"
else
  MIRACULIX_CXXFLAGS="$CXX_FLAGS"
fi

echo Using custom CXXFLAGS: $MIRACULIX_CXXFLAGS

sed -e "s|@MIRACULIX_CXXFLAGS@|$MIRACULIX_CXXFLAGS|" \
    src/Makevars.in > src/Makevars.win

